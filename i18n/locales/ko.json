    },
    "unity": {
      "name": "Unity",
      "tagline": "CSS 단위 변환기",
      "description": "구성 가능한 기준 크기를 사용해 px, rem, em, pt, % 간 변환합니다. 한 단위를 편집하면 나머지가 다시 계산됩니다."
    },
    "timely": {
      "name": "Timely",
      "tagline": "타임스탬프와 날짜 변환",
      "description": "어떤 형식이든 편집하면(UNIX 초/밀리초, ISO 8601 UTC/로컬, RFC 2822) 다른 형식이 업데이트됩니다. 요일, 상대 시간 및 시간대를 표시합니다."
    },
    "basey": {
      "name": "Basey",
      "tagline": "진법 간 변환",
      "description": "2진수, 8진수, 10진수, 16진수 간 변환합니다. 모든 크기의 정수를 지원합니다 (BigInt)."
    },
    "lapsy": {
      "name": "Lapsy",
      "tagline": "두 날짜 사이의 시간",
      "description": "두 날짜 사이 또는 한 날짜에서 현재까지의 시간을 계산합니다 (실시간). 연, 월, 일, 시, 분, 초를 표시합니다."
    },
    "picky": {
      "name": "Picky",
      "tagline": "이미지에서 색상 추출 스포이트",
      "description": "이미지를 불러오고, 마우스를 올려 확인한 뒤 클릭하여 색상을 선택하세요. HEX, RGB, HSL과 클립보드 복사 기능을 제공합니다. 모두 브라우저에서 처리됩니다."
    },
    "markpdf": {
      "name": "Markpdf",
      "tagline": "PDF에 워터마크 추가",
      "description": "사용자 정의 가능한 색상, 불투명도, 크기, 각도 및 위치(타일 패턴 포함)로 PDF 페이지에 텍스트 워터마크를 추가합니다. 모두 브라우저에서 처리됩니다."
    },
    "cronpad": {
      "name": "Cronpad",
      "tagline": "cron 표현식 설명",
      "description": "cron 표현식을 자연어로 번역하고 구문을 검증하며 다음 실행 시간을 미리 봅니다. @daily 및 @hourly 같은 프리셋을 지원합니다. 모두 브라우저에서 처리됩니다."
    },
    "jsonpad": {
      "name": "Jsonpad",
      "tagline": "JSON 포맷 및 검증",
      "description": "JSON을 붙여넣고 검증한 뒤 원하는 들여쓰기로 보기 좋게 출력합니다. 압축, 키 정렬, 통계 확인이 가능합니다. 모두 브라우저에서 처리됩니다."
    }
