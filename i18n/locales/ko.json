    },
    "metapdf": {
      "name": "Metapdf",
      "tagline": "PDF 메타데이터 편집",
      "description": "PDF의 제목, 작성자, 주제, 키워드 및 날짜를 읽고 수정합니다. 모두 브라우저에서 처리됩니다."
    },
    "combiny": {
