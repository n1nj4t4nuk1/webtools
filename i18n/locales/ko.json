    },
    "yamljson": {
      "name": "YamlJson",
      "tagline": "YAML과 JSON 간 변환",
      "description": "YAML이나 JSON을 붙여넣으면 즉시 다른 형식을 얻을 수 있습니다. 형식을 자동 감지하고 줄과 열로 오류를 표시합니다. 모두 브라우저에서 처리됩니다."
    },
    "urlpad": {
      "name": "Urlpad",
      "tagline": "URL 인코딩 및 디코딩",
      "description": "텍스트와 URL을 인코딩하거나 디코딩합니다. 자동 감지와 두 가지 변형 (전체 URI 또는 컴포넌트). 모두 브라우저에서 처리됩니다."
    },
    "codecpad": {
      "name": "Codecpad",
      "tagline": "여러 형식으로 텍스트를 한 번에 인코딩",
      "description": "UTF-8, Base64, Base64 URL-safe, Base32, Hex 및 Base58. 어떤 형식이든 편집하면 나머지가 즉시 업데이트됩니다."
    },
    "jwtdecoder": {
      "name": "JwtDecoder",
      "tagline": "JSON Web Tokens 디코딩",
      "description": "JWT를 붙여넣으면 Header와 Payload가 보기 좋게 출력되고, 유효성 상태와 표준 클레임(exp, iat, nbf…)이 해석되어 표시됩니다."
    },
    "diffy": {
      "name": "Diffy",
      "tagline": "두 텍스트를 비교하고 변경 사항을 강조 표시",
      "description": "줄, 단어 또는 문자 단위로 diff를 비교하고 강조 표시합니다. 대소문자나 공백을 무시하는 옵션이 있습니다. 모두 브라우저에서 처리됩니다."
    },
    "gradienty": {
      "name": "Gradienty",
      "tagline": "CSS 그라데이션 생성기",
      "description": "여러 정지점이 있는 선형, 방사형, 원뿔형 그라데이션을 만들고 실시간 미리보기를 확인하며 CSS를 복사합니다."
    },
    "shadowy": {
      "name": "Shadowy",
      "tagline": "box-shadow 생성기",
      "description": "오프셋, 블러, 확산, 색상, 알파, 내부 그림자를 적용합니다. 실시간 미리보기와 함께 여러 레이어를 사용할 수 있습니다."
    },
    "colory": {
      "name": "Colory",
