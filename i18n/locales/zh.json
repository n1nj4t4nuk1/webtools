  "landing": {
    "title": "在浏览器中运行的工具",
    "description": "一系列无需服务器的网络实用工具。您的文件永远不会离开您的设备。",
    "categories": {
      "imageEdit": "图片编辑",
      "documents": "文档",
      "privacy": "隐私",
      "generators": "生成器",
      "dev": "开发",
      "design": "设计",
      "calculators": "计算器"
    }
  },
  "tools": {
    "mochi": {
      "name": "Mochi",
      "tagline": "调整图片尺寸",
      "description": "直接在浏览器中减小图片的像素尺寸。无需上传，无需服务器。"
    },
    "metaimg": {
      "name": "Metaimg",
      "tagline": "编辑 EXIF 元数据",
      "description": "读取、修改或删除 JPEG 照片的 EXIF 元数据。一切都在浏览器中完成。"
    },
    "convy": {
      "name": "Convy",
      "tagline": "在不同格式间转换图片",
      "description": "在 PNG、JPG 和 WebP 之间转换，可控制质量。所有处理都在您的浏览器中完成，无需上传。"
    },
    "pixely": {
      "name": "Pixely",
      "tagline": "将图片像素化",
      "description": "通过调整块大小，为图片应用像素艺术效果。实时预览。所有处理都在您的浏览器中完成。"
    },
    "createpass": {
      "name": "Createpass",
      "tagline": "生成强密码",
      "description": "使用浏览器加密技术创建随机密码。它们永远不会离开您的设备。"
    },
    "hashy": {
      "name": "Hashy",
      "tagline": "计算哈希并验证完整性",
      "description": "计算文本或文件的 SHA-1、SHA-256、SHA-384 和 SHA-512 哈希。与期望的哈希值比较以验证下载。"
    },
    "stapler": {
      "name": "Stapler",
      "tagline": "将多个 PDF 合并为一个",
      "description": "按您想要的顺序将多个 PDF 文件合并为一个。所有处理都在您的浏览器中完成。"
    },
    "wordy": {
      "name": "Wordy",
      "tagline": "统计单词和字符",
      "description": "分析文本或文本文件：单词、字符、行数、段落和预计阅读时间。"
    },
    "scissor": {
      "name": "Scissor",
      "tagline": "从 PDF 提取页面",
      "description": "从 PDF 中选择页面或范围并下载为新文件。所有处理都在您的浏览器中完成。"
    },
    "pdfspinner": {
      "name": "PdfSpinner",
      "tagline": "旋转 PDF 页面",
      "description": "将所有页面或特定范围旋转 90°、180° 或 270°。所有处理都在您的浏览器中完成。"
    },
    "albumy": {
      "name": "Albumy",
      "tagline": "将多张图片合并为一个 PDF",
      "description": "加载多张图片，排序并下载为单个 PDF。A4、Letter 或自适应每张图片的尺寸。所有处理都在您的浏览器中完成。"
    },
    "metapdf": {
      "name": "Metapdf",
      "tagline": "编辑 PDF 元数据",
      "description": "读取并修改 PDF 的标题、作者、主题、关键词和日期。所有处理都在您的浏览器中完成。"
    },
    "combiny": {
      "name": "Combiny",
      "tagline": "组合字段生成变体（邮箱、用户名…）",
      "description": "使用可配置的分隔符和后缀生成多个字段的组合。适用于邮箱列表、用户名、slug 或 ID。"
    },
    "csvjson": {
      "name": "CsvJson",
      "tagline": "在 CSV 和 JSON 之间转换",
      "description": "粘贴 CSV 或 JSON，立即获得另一种格式。自动检测分隔符和格式。所有处理都在您的浏览器中完成。"
    },
    "lorempad": {
      "name": "Lorempad",
      "tagline": "生成 Lorem ipsum 文本",
      "description": "以段落、句子或单词生成占位文本。可选择以经典的 \"Lorem ipsum dolor sit amet…\" 开头，输出为纯文本或 HTML。"
    },
    "qrgen": {
      "name": "Qrgen",
      "tagline": "生成 QR 码",
      "description": "为 URL 或文本创建 QR 码。自定义颜色、大小、纠错级别，并下载为 SVG 或 PNG。"
    },
    "regexpad": {
      "name": "Regexpad",
      "tagline": "测试正则表达式并替换文本",
      "description": "构建正则表达式，查看高亮匹配，并应用替换（支持 $1, $2…）。所有处理都在您的浏览器中完成。"
    },
    "yamljson": {
      "name": "YamlJson",
      "tagline": "在 YAML 和 JSON 之间转换",
      "description": "粘贴 YAML 或 JSON，立即获得另一种格式。自动检测格式并显示带行列号的错误。所有处理都在您的浏览器中完成。"
    },
    "urlpad": {
      "name": "Urlpad",
      "tagline": "URL 编码和解码",
      "description": "对文本和 URL 进行编码或解码。自动检测和两种变体（完整 URI 或组件）。所有处理都在您的浏览器中完成。"
    },
    "codecpad": {
      "name": "Codecpad",
      "tagline": "同时以多种格式编码文本",
      "description": "UTF-8、Base64、Base64 URL-safe、Base32、Hex 和 Base58。编辑任何格式，其他格式即时更新。"
    },
    "jwtdecoder": {
      "name": "JwtDecoder",
      "tagline": "解码 JSON Web Token",
      "description": "粘贴 JWT 即可查看格式化的 header 和 payload、有效性状态以及标准 claim（exp、iat、nbf…）的解读。"
    },
    "diffy": {
      "name": "Diffy",
      "tagline": "比较两段文本并高亮显示变化",
      "description": "按行、单词或字符进行 diff 并高亮显示。支持忽略大小写或空格的选项。所有处理都在您的浏览器中完成。"
    },
    "gradienty": {
      "name": "Gradienty",
      "tagline": "CSS 渐变生成器",
      "description": "使用多个色标创建线性、径向和锥形渐变，实时预览并复制 CSS。"
    },
    "shadowy": {
      "name": "Shadowy",
      "tagline": "box-shadow 生成器",
      "description": "可配置 offset、blur、spread、color、alpha 和 inset 的阴影。支持多层和实时预览。"
    },
    "colory": {
      "name": "Colory",
      "tagline": "色彩选择器、调色板和 WCAG 对比度",
      "description": "选择颜色，在 HEX/RGB/HSL 间转换，生成调色板并测量与白色和黑色的 WCAG 对比度。"
    },
    "unity": {
      "name": "Unity",
      "tagline": "CSS 单位转换器",
      "description": "使用可配置的基础大小在 px、rem、em、pt 和 % 间转换。编辑任何单位都会重新计算其他单位。"
    },
    "timely": {
      "name": "Timely",
      "tagline": "时间戳和日期转换",
      "description": "编辑任意格式（UNIX 秒/毫秒、ISO 8601 UTC/本地、RFC 2822），其他会自动更新。显示星期、相对时间和时区。"
    },
    "basey": {
      "name": "Basey",
      "tagline": "数字进制转换器",
      "description": "在二进制、八进制、十进制和十六进制之间转换。支持任意大小的整数（BigInt）。"
    },
    "lapsy": {
      "name": "Lapsy",
      "tagline": "两个日期之间的时间",
      "description": "计算两个日期之间或从某个日期到现在的时间（实时）。显示年、月、日、时、分、秒。"
    },
    "picky": {
      "name": "Picky",
      "tagline": "从图片中拾取颜色",
      "description": "加载图片，悬停查看并点击拾取颜色。支持 HEX、RGB 和 HSL，可一键复制到剪贴板。全部在您的浏览器中完成。"
    },
    "markpdf": {
      "name": "Markpdf",
      "tagline": "为 PDF 添加水印",
      "description": "为 PDF 页面添加文字水印，可自定义颜色、不透明度、大小、角度和位置（包括平铺图案）。全部在您的浏览器中完成。"
    },
    "cronpad": {
      "name": "Cronpad",
      "tagline": "解释 cron 表达式",
      "description": "将 cron 表达式翻译为易懂的文字，验证其语法并预览接下来的运行时间。支持 @daily 和 @hourly 等预设。全部在您的浏览器中完成。"
    },
    "mdtably": {
      "name": "Mdtably",
      "tagline": "CSV 转 Markdown 表格",
      "description": "将 CSV 转换为完美对齐的 Markdown 表格，可按列设置对齐方式。自动检测分隔符，支持无表头输入。全部在您的浏览器中完成。"
    },
    "brandy": {
      "name": "Brandy",
      "tagline": "为图片添加水印",
      "description": "在照片上添加文字或图片水印，可设置位置、不透明度、旋转、大小和平铺图案。实时预览。全部在您的浏览器中完成。"
    },
    "randy": {
      "name": "Randy",
      "tagline": "带种子的随机数",
      "description": "可重现的伪随机生成器：相同种子 = 相同序列。整数、浮点数或从列表中选取，可有放回或无放回。mulberry32 和 xoshiro128** 算法。全部在您的浏览器中完成。"
    },
    "croppy": {
      "name": "Croppy",
      "tagline": "裁剪图片",
      "description": "通过拖动或精确像素值选择区域。锁定宽高比（1:1、4:3、16:9…）。导出无损 PNG 或重新编码为 JPG/WebP。全部在您的浏览器中完成。"
    },
    "yieldy": {
      "name": "Yieldy",
      "tagline": "复利计算器",
      "description": "模拟本金在复利和定期投入下的增长。以您选择的货币逐年显示结果。全部在您的浏览器中完成。"
    },
    "jsonpad": {
      "name": "Jsonpad",
      "tagline": "格式化和验证 JSON",
      "description": "粘贴 JSON，验证并按您喜欢的缩进格式化。压缩、排序键和显示统计信息。所有处理都在您的浏览器中完成。"
    }
  },
